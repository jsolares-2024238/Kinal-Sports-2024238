# Server Configuration
PORT=3002

# MongoDB
URI_MONGODB=mongodb://localhost:27017/kinal-sports-admin

# CORS - Allowed Origins (comma-separated or '*' for all)
ADMIN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

# JWT Configuration (tokens vienen del servicio de autenticación)
JWT_SECRET=your-jwt-secret-key-here
JWT_ISSUER=auth-service
JWT_AUDIENCE=admin-service

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload/
# Carpeta donde se subirán las imágenes de campos deportivos
CLOUDINARY_FOLDER=admin_service/fields
# Imagen por defecto para campos sin imagen (opcional)
CLOUDINARY_DEFAULT_FIELD_FILENAME=default-field.png
CLOUDINARY_DEFAULT_FIELD=${CLOUDINARY_FOLDER}/${CLOUDINARY_DEFAULT_FIELD_FILENAME}
